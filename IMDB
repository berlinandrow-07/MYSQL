CREATE TABLE ARTIST(
MOVIE_ID INT,
ARTIST_ID INT AUTO_INCREMENT PRIMARY KEY,
ARTIST_NAME VARCHAR (200),
SKILLS VARCHAR (200),
ROLES VARCHAR(200),
FOREIGN KEY (MOVIE_ID) REFERENCES MOVIE(MOVIE_ID)
);

