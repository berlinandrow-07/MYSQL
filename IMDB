CREATE TABLE MULTIPLE_GENRE(
MOVIE_ID INT,
GENRE_ID INT AUTO_INCREMENT PRIMARY KEY,
GENRE VARCHAR(200),
FOREIGN KEY (MOVIE_ID) REFERENCES MOVIE(MOVIE_ID));

