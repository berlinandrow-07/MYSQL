CREATE DATABASE IMDB;
USE IMDB;

CREATE TABLE MOVIE(
 MOVIE_ID INT AUTO_INCREMENT PRIMARY KEY,
 MOVIE_NAME VARCHAR(50),
 MEDIA_TYPE VARCHAR(50),
 MEDIA_URL VARCHAR(200));
 
