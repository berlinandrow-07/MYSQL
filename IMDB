SELECT * FROM MOVIE;
SELECT MOVIE_NAME, GENRE FROM MOVIE M LEFT JOIN MULTIPLE_GENRE MG ON M.MOVIE_ID= MG.MOVIE_ID ;
SELECT MOVIE_NAME, REVIEWS FROM MOVIE M LEFT JOIN USERS U ON M.MOVIE_ID= U.MOVIE_ID ;
SELECT ARTIST_NAME,MOVIE_NAME, SKILLS FROM MOVIE M LEFT JOIN ARTIST A ON M.MOVIE_ID= A.MOVIE_ID ;
SELECT ARTIST_NAME,MOVIE_NAME, ROLES FROM MOVIE M LEFT JOIN ARTIST A ON M.MOVIE_ID= A.MOVIE_ID ;

